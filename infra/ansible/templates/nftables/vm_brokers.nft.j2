flush ruleset

table inet filter {
  chain input {
    type filter hook input priority 0; policy drop;
    iif "lo" accept
    ct state established,related accept
    tcp dport 22 ip saddr {{ admin_cidr }} accept
    tcp dport 9092 ip saddr { {{ hostvars['vm-init'].private_ip }}, {{ hostvars['vm-api'].private_ip }}, {{ hostvars['vm-core'].private_ip }}, {{ hostvars['vm-app'].private_ip }} } accept
    tcp dport 5672 ip saddr { {{ hostvars['vm-api'].private_ip }}, {{ hostvars['vm-core'].private_ip }}, {{ hostvars['vm-app'].private_ip }} } accept
    tcp dport 9093 ip saddr { {{ private_ip }} } accept
  }

  chain forward {
    type filter hook forward priority 0; policy drop;
  }

  chain output {
    type filter hook output priority 0; policy drop;
    oif "lo" accept
    ct state established,related accept
    tcp dport { 80, 443 } accept
    tcp dport 443 ip daddr {{ hostvars['vm-auth'].private_ip }} accept
  }
}

