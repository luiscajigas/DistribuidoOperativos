[Unit]
After=docker.service
Requires=docker.service

[Service]
ExecStart=/usr/bin/docker run --rm --name regional-dashboard-worker --network host \
  --env-file /opt/zero-trust/services/regional-dashboard-worker/service.env \
  -v /opt/zero-trust/certs:/certs:ro \
  zt/regional-dashboard-worker:local
ExecStop=/usr/bin/docker stop regional-dashboard-worker
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
