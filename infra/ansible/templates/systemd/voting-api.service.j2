[Unit]
After=docker.service
Requires=docker.service

[Service]
ExecStart=/usr/bin/docker run --rm --name voting-api --network host --env-file /opt/zero-trust/services/voting-api/service.env -v /opt/zero-trust/certs:/certs:ro -v /opt/zero-trust/services/voting-api/tls:/tls:ro zt/voting-api:local
ExecStop=/usr/bin/docker stop voting-api
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target

