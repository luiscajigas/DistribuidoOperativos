[Unit]
After=docker.service
Requires=docker.service

[Service]
ExecStart=/usr/bin/docker run --rm --name global-dashboard-worker --network host \
  --env-file /opt/zero-trust/services/global-dashboard-worker/service.env \
  -v /opt/zero-trust/certs:/certs:ro \
  zt/global-dashboard-worker:local
ExecStop=/usr/bin/docker stop global-dashboard-worker
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
